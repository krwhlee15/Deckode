        { "id": "s2-c2-b", "type": "text", "content": "Rate at which the price level rises. Measured by CPI or the GDP deflator. Moderate is healthy; runaway is corrosive to savings and contracts.", "position": { "x": 340, "y": 215 }, "size": { "w": 260, "h": 90 }, "style": { "fontSize": 12, "color": "#0A2540", "lineHeight": 1.6 } },
