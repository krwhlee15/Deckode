        { "id": "s2-c1-b", "type": "text", "content": "Total market value of final goods and services produced in a period. The headline number everyone quotes — and everyone argues about.", "position": { "x": 60, "y": 215 }, "size": { "w": 260, "h": 90 }, "style": { "fontSize": 12, "color": "#0A2540", "lineHeight": 1.6 } },
