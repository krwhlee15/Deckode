        { "id": "s2-c3-b", "type": "text", "content": "Share of the labor force actively seeking work. Tracks the business cycle and sets the political temperature of every news cycle.", "position": { "x": 620, "y": 215 }, "size": { "w": 260, "h": 90 }, "style": { "fontSize": 12, "color": "#0A2540", "lineHeight": 1.6 } },
