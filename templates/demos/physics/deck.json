        { "id": "s6-rule", "type": "shape", "shape": "rectangle", "position": { "x": 60, "y": 62 }, "size": { "w": 840, "h": 1 }, "style": { "fill": "#4FC3F7", "stroke": "#4FC3F7", "strokeWidth": 0 } },
        { "id": "s6-title", "type": "text", "content": "# Quantum is the OS of reality", "position": { "x": 60, "y": 90 }, "size": { "w": 840, "h": 60 }, "style": { "fontSize": 40, "color": "#EAE6DF" } },
        { "id": "s6-sub", "type": "text", "content": "Every piece of modern technology is a quantum effect, engineered into existence.", "position": { "x": 60, "y": 155 }, "size": { "w": 840, "h": 28 }, "style": { "fontSize": 15, "color": "#B47AEA" } },
