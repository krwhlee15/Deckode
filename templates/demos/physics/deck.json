        { "id": "s5-side-h", "type": "text", "content": "**Energy quantisation**", "position": { "x": 570, "y": 150 }, "size": { "w": 330, "h": 24 }, "style": { "fontSize": 15, "color": "#4FC3F7" } },
        { "id": "s5-eq2", "type": "text", "content": "$$ E_n = \\frac{n^2 \\pi^2 \\hbar^2}{2 m L^2} $$", "position": { "x": 570, "y": 175 }, "size": { "w": 330, "h": 80 }, "style": { "fontSize": 22, "color": "#EAE6DF", "textAlign": "center", "verticalAlign": "middle" } },
        { "id": "s5-side-b", "type": "text", "content": "Confining a particle to a region of size $L$ forces its wave to have wavelengths that fit integer half-cycles — and forces its energy to be discrete.\n\nShrink $L$ → energies spread apart.\nMake $m$ larger → energies compress toward classical continuum.", "position": { "x": 570, "y": 258 }, "size": { "w": 330, "h": 180 }, "style": { "fontSize": 12, "color": "#9DA8B3", "lineHeight": 1.6 } }
      ]
