        { "id": "s6-quote", "type": "text", "content": "*\"Anyone who is not shocked by quantum theory has not understood it.\"*  — Niels Bohr", "position": { "x": 60, "y": 410 }, "size": { "w": 840, "h": 24 }, "style": { "fontSize": 13, "color": "#EAE6DF" } },
