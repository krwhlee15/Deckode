        { "id": "s3-rule", "type": "shape", "shape": "rectangle", "position": { "x": 60, "y": 62 }, "size": { "w": 840, "h": 1 }, "style": { "fill": "#4FC3F7", "stroke": "#4FC3F7", "strokeWidth": 0 } },
        { "id": "s3-title", "type": "text", "content": "# The Schrödinger equation", "position": { "x": 60, "y": 80 }, "size": { "w": 840, "h": 44 }, "style": { "fontSize": 28, "color": "#EAE6DF" } },
        { "id": "s3-eq-bg", "type": "shape", "shape": "rectangle", "position": { "x": 60, "y": 140 }, "size": { "w": 840, "h": 90 }, "style": { "fill": "#1A2330", "stroke": "#4FC3F7", "strokeWidth": 1, "borderRadius": 6 } },
        { "id": "s3-eq", "type": "text", "content": "$$ i\\hbar\\, \\frac{\\partial}{\\partial t} \\Psi(\\mathbf{r}, t) \\;=\\; \\hat{H}\\, \\Psi(\\mathbf{r}, t) $$", "position": { "x": 60, "y": 140 }, "size": { "w": 840, "h": 90 }, "style": { "fontSize": 28, "color": "#EAE6DF", "textAlign": "center", "verticalAlign": "middle" } },
