        { "id": "s6-c4-h", "type": "text", "content": "**Your DNA**", "position": { "x": 736, "y": 215 }, "size": { "w": 148, "h": 24 }, "style": { "fontSize": 15, "color": "#B47AEA" } },
        { "id": "s6-c4-b", "type": "text", "content": "Hydrogen bonds and base pairing — chemistry is just applied quantum mechanics.", "position": { "x": 736, "y": 245 }, "size": { "w": 148, "h": 110 }, "style": { "fontSize": 12, "color": "#9DA8B3", "lineHeight": 1.6 } },
