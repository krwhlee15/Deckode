        { "id": "s6-c1-h", "type": "text", "content": "**Transistors**", "position": { "x": 76, "y": 215 }, "size": { "w": 168, "h": 24 }, "style": { "fontSize": 15, "color": "#4FC3F7" } },
        { "id": "s6-c1-b", "type": "text", "content": "Band gaps, p-n junctions, and tunneling current — a 5-nm MOSFET is a quantum device.", "position": { "x": 76, "y": 245 }, "size": { "w": 168, "h": 110 }, "style": { "fontSize": 12, "color": "#9DA8B3", "lineHeight": 1.6 } },
        { "id": "s6-c2-bg", "type": "shape", "shape": "rectangle", "position": { "x": 280, "y": 200 }, "size": { "w": 200, "h": 170 }, "style": { "fill": "#1A2330", "stroke": "#2A3541", "strokeWidth": 1, "borderRadius": 6 } },
        { "id": "s6-c2-h", "type": "text", "content": "**Lasers**", "position": { "x": 296, "y": 215 }, "size": { "w": 168, "h": 24 }, "style": { "fontSize": 15, "color": "#4FC3F7" } },
        { "id": "s6-c2-b", "type": "text", "content": "Stimulated emission and population inversion — discrete energy levels turned into coherent light.", "position": { "x": 296, "y": 245 }, "size": { "w": 168, "h": 110 }, "style": { "fontSize": 12, "color": "#9DA8B3", "lineHeight": 1.6 } },
        { "id": "s6-c3-bg", "type": "shape", "shape": "rectangle", "position": { "x": 500, "y": 200 }, "size": { "w": 200, "h": 170 }, "style": { "fill": "#1A2330", "stroke": "#2A3541", "strokeWidth": 1, "borderRadius": 6 } },
        { "id": "s6-c3-h", "type": "text", "content": "**MRI**", "position": { "x": 516, "y": 215 }, "size": { "w": 168, "h": 24 }, "style": { "fontSize": 15, "color": "#B47AEA" } },
        { "id": "s6-c3-b", "type": "text", "content": "Nuclear spin precession in a magnetic field. Maps hydrogen density in soft tissue non-invasively.", "position": { "x": 516, "y": 245 }, "size": { "w": 168, "h": 110 }, "style": { "fontSize": 12, "color": "#9DA8B3", "lineHeight": 1.6 } },
