      "elements": [
        { "id": "s4-tag", "type": "text", "content": "§3  A HARD LIMIT", "position": { "x": 60, "y": 40 }, "size": { "w": 840, "h": 16 }, "style": { "fontSize": 10, "color": "#4FC3F7" } },
        { "id": "s4-rule", "type": "shape", "shape": "rectangle", "position": { "x": 60, "y": 62 }, "size": { "w": 840, "h": 1 }, "style": { "fill": "#4FC3F7", "stroke": "#4FC3F7", "strokeWidth": 0 } },
        { "id": "s4-title", "type": "text", "content": "# Heisenberg's uncertainty principle", "position": { "x": 60, "y": 80 }, "size": { "w": 840, "h": 44 }, "style": { "fontSize": 26, "color": "#EAE6DF" } },
        { "id": "s4-eq", "type": "text", "content": "$$ \\Delta x \\cdot \\Delta p \\;\\geq\\; \\frac{\\hbar}{2} $$", "position": { "x": 60, "y": 135 }, "size": { "w": 440, "h": 95 }, "style": { "fontSize": 36, "color": "#B47AEA", "textAlign": "center", "verticalAlign": "middle" } },
        { "id": "s4-tikz", "type": "tikz", "content": "\\begin{tikzpicture}[scale=0.85]\n\\path[use as bounding box] (-0.8,-1.8) rectangle (7.2,2.2);\n\\draw[->, gray!50] (-0.5,0) -- (7,0) node[below right, text=white, font=\\scriptsize] {$x$};\n\\draw[->, gray!50] (0,-1.5) -- (0,1.9) node[left, text=white, font=\\scriptsize] {$\\psi(x)$};\n\\draw[thick, cyan!70, domain=-0.3:6.8, samples=200] plot (\\x, {1.2*exp(-(\\x-3)*(\\x-3)/1.5)*cos(deg(4*\\x))});\n\\draw[thick, violet!60, domain=0.3:5.7, dashed] plot (\\x, {1.2*exp(-(\\x-3)*(\\x-3)/1.5)});\n\\draw[thick, violet!60, domain=0.3:5.7, dashed] plot (\\x, {-1.2*exp(-(\\x-3)*(\\x-3)/1.5)});\n\\draw[violet!70, <->, thick] (1.5, -1.35) -- (4.5, -1.35) node[midway, below, text=white, font=\\scriptsize] {$\\Delta x$};\n\\node[text=cyan!70, font=\\scriptsize] at (5.9, -0.8) {wave packet};\n\\node[text=violet!60, font=\\scriptsize, anchor=west] at (5.0, 1.0) {envelope};\n\\end{tikzpicture}", "position": { "x": 530, "y": 140 }, "size": { "w": 370, "h": 200 }, "style": { "backgroundColor": "#0F1419" } },
        { "id": "s4-rule2", "type": "shape", "shape": "rectangle", "position": { "x": 60, "y": 345 }, "size": { "w": 840, "h": 1 }, "style": { "fill": "#2A3541", "stroke": "#2A3541", "strokeWidth": 0 } },
        { "id": "s4-left-h", "type": "text", "content": "NOT A MEASUREMENT LIMIT", "position": { "x": 60, "y": 360 }, "size": { "w": 400, "h": 14 }, "style": { "fontSize": 10, "color": "#4FC3F7" } },
        { "id": "s4-left-b", "type": "text", "content": "Position and momentum aren't hidden properties we fail to measure. They're Fourier conjugates of the same wave — narrowing one *necessarily* widens the other.", "position": { "x": 60, "y": 380 }, "size": { "w": 400, "h": 70 }, "style": { "fontSize": 12, "color": "#9DA8B3", "lineHeight": 1.6 } },
        { "id": "s4-right-h", "type": "text", "content": "PRACTICAL CONSEQUENCES", "position": { "x": 500, "y": 360 }, "size": { "w": 400, "h": 14 }, "style": { "fontSize": 10, "color": "#4FC3F7" } },
        { "id": "s4-right-b", "type": "text", "content": "Zero-point energy, tunneling, the stability of atoms (electrons can't sit still at the nucleus) — all follow from this single inequality.", "position": { "x": 500, "y": 380 }, "size": { "w": 400, "h": 70 }, "style": { "fontSize": 12, "color": "#9DA8B3", "lineHeight": 1.6 } }
      ]
    },
